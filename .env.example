# =============================================================================
# Shared database connection (DB_*)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DBNAME=fundingpulse

# =============================================================================
# API service (FDA_*)
# =============================================================================

# CORS (FDA_CORS_*)
FDA_CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8000"]
FDA_CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
FDA_CORS_ALLOW_HEADERS=["*"]
FDA_CORS_ALLOW_CREDENTIALS=false
FDA_CORS_MAX_AGE=600

# SQLAlchemy tuning (FDA_DB_*): rare manual overrides; defaults live in code.
# FDA_DB_ENGINE_KWARGS={"pool_size":10,"max_overflow":20,"pool_pre_ping":true}
# FDA_DB_SESSION_KWARGS={"expire_on_commit":false}

# =============================================================================
# Tracker service (FT_*)
# =============================================================================

# Exchange selection (empty / unset → run all)
# FT_EXCHANGES=hyperliquid,bybit

# Per-exchange debug logging scopes
# FT_DEBUG_EXCHANGES=hyperliquid
# FT_DEBUG_EXCHANGES_LIVE=hyperliquid

# Multi-instance sharding for local runs without supervisord
# FT_INSTANCE_ID=0
# FT_TOTAL_INSTANCES=1

# SQLAlchemy tuning (FT_DB_*): rare manual overrides; defaults live in code.
# FT_DB_ENGINE_KWARGS={"pool_size":10,"max_overflow":20,"pool_pre_ping":true}
# FT_DB_SESSION_KWARGS={"expire_on_commit":false}

# Supervisord fan-out inside the tracker container: spawns N funding-tracker
# processes, each with --instance-id / --total-instances set automatically.
# FT_INSTANCE_COUNT=3

# =============================================================================
# Compose deployment (not read by Python)
# =============================================================================

# Host port for the api container.
# API_PORT=8000

# Host port for the frontend container in local Docker Compose runs. On prod
# hosts, the frontend joins the reverse-proxy network instead of publishing this
# port directly.
# FRONTEND_PORT=3000

# On prod hosts: enable the prod override (api joins an external reverse-proxy
# network, host ports are not published). Leave unset for local dev.
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml

# External docker network the reverse proxy (e.g. Nginx Proxy Manager) runs on.
# Required when COMPOSE_FILE includes docker-compose.prod.yml.
# PROXY_DOCKER_NETWORK=proxy
