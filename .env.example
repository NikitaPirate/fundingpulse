# =============================================================================
# Database Configuration
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DBNAME=fundingpulse

# =============================================================================
# Tracker Configuration
# =============================================================================

# Optional SQLAlchemy kwargs (JSON)
# FT_ENGINE_KWARGS={"pool_size":30,"max_overflow":200,"pool_pre_ping":true}
# FT_SESSION_KWARGS={"expire_on_commit":false}

# Optional exchange selection (empty or unset means "run all")
# EXCHANGES=hyperliquid,bybit

# Optional debug scopes
# DEBUG_EXCHANGES=hyperliquid
# DEBUG_EXCHANGES_LIVE=hyperliquid

# Optional multi-instance process settings for local runs
# INSTANCE_ID=0
# TOTAL_INSTANCES=1

# =============================================================================
# API Configuration
# =============================================================================

# CORS
FDA_CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8000"]
FDA_CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
FDA_CORS_ALLOW_HEADERS=["*"]
FDA_CORS_ALLOW_CREDENTIALS=false
FDA_CORS_MAX_AGE=600

# Optional SQLAlchemy kwargs (JSON)
# FDA_ENGINE_KWARGS={"pool_size":10,"max_overflow":50,"pool_pre_ping":true}
# FDA_SESSION_KWARGS={"expire_on_commit":false}
