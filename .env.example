# =============================================================================
# Shared database connection (DB_*)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DBNAME=fundingpulse

# =============================================================================
# API service (FDA_*)
# =============================================================================

# CORS (FDA_CORS_*)
FDA_CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8000"]
FDA_CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
FDA_CORS_ALLOW_HEADERS=["*"]
FDA_CORS_ALLOW_CREDENTIALS=false
FDA_CORS_MAX_AGE=600

# SQLAlchemy tuning (FDA_DB_*)
# FDA_DB_ENGINE_KWARGS={"pool_size":10,"max_overflow":50,"pool_pre_ping":true}
# FDA_DB_SESSION_KWARGS={"expire_on_commit":false}

# Host port for the api container (compose-level substitution, not read by Python)
# API_PORT=8000

# =============================================================================
# Tracker service (FT_*)
# =============================================================================

# Exchange selection (empty / unset → run all)
# FT_EXCHANGES=hyperliquid,bybit

# Per-exchange debug logging scopes
# FT_DEBUG_EXCHANGES=hyperliquid
# FT_DEBUG_EXCHANGES_LIVE=hyperliquid

# Multi-instance sharding for local runs without supervisord
# FT_INSTANCE_ID=0
# FT_TOTAL_INSTANCES=1

# SQLAlchemy tuning (FT_DB_*)
# FT_DB_ENGINE_KWARGS={"pool_size":30,"max_overflow":200,"pool_pre_ping":true}
# FT_DB_SESSION_KWARGS={"expire_on_commit":false}

# Supervisord fan-out inside the tracker container: spawns N funding-tracker
# processes, each with --instance-id / --total-instances set automatically.
# FT_INSTANCE_COUNT=3
